<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>CSS-07A</title>
    <style>
        #container {
            width: 200px;
        }
        ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
            font-family: Arial, sans-serif;
        }
        li {
            margin-bottom: 5px;
        }
        a {
            display: block;
            text-decoration: none;
            background-color: #333;
            color: white;
            padding: 10px;
            border-radius: 4px;
        }
        a:hover {
            background-color: #555;
            color: #ffcc00;
        }
        a:active {
            background-color: #ffcc00;
            color: black;
        }
    </style>
</head> 
<body> 
    <h2>CSS menu pionowe</h2>
    <div id="container"> 
        <ul>
            <li><a href="#">Strona główna</a></li>
            <li><a href="#">Aktualności</a></li>
            <li><a href="#">Galeria</a></li>
            <li><a href="#">Kontakt</a></li>
        </ul>
    </div>   
</body> 
</html>
